# ---- Synced state store (Upstash Redis via Vercel Marketplace) ----
# Add the "Upstash for Redis" integration on Vercel and it injects these two
# automatically. For local dev, paste them into a .env.local file.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ---- Board access key ----
# A single shared password that gates reading/writing the board.
# Pick anything long and private. The website asks for it once and remembers it.
# The weekly updater script must send the same value.
BOARD_KEY=change-me-to-something-long-and-private

# ---- Used by the weekly updater script only (not by the website) ----
# The public URL of your deployed board, e.g. https://goku-kanban.vercel.app
BOARD_URL=
